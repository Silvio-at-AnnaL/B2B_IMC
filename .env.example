# ============================================================
# Die EINZIGEN Werte, die ausserhalb des Admin-Bereichs gepflegt
# werden. Alles andere (LLM-Keys, Mailserver, externe APIs) wird
# verschluesselt in der DB gespeichert und im Admin-UI verwaltet.
# ============================================================

# Neon-Postgres-Verbindung (DEV): Connection String aus dem Neon-Dashboard
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/annalyst?sslmode=require"

# 32-Byte-Schluessel (hex) fuer die AES-256-GCM-Verschluesselung der
# in der DB abgelegten Credentials. Erzeugen mit:
#   openssl rand -hex 32
APP_ENCRYPTION_KEY=""

# Auth.js Session-Secret. Erzeugen mit: openssl rand -base64 32
AUTH_SECRET=""

# ============================================================
# NUR fuer das einmalige Seeden (pnpm run db:seed), solange das Admin-CRUD
# fuer Provider/Integrationen fehlt. Diese Werte werden beim Seeden
# VERSCHLUESSELT in die DB geschrieben und NICHT zur Laufzeit gelesen.
# Nach dem Seed wieder entfernen. Optional.
# ============================================================
# SEED_ADMIN_PASSWORD=""   # Initiales Admin-Passwort (sonst "change-me-now")
# SEED_ANTHROPIC_KEY=""    # Anthropic-API-Key fuer den LLM-Provider
# SEED_LLM_MODEL=""        # optionales Modell-Override fuer den LLM-Provider
# SEED_SERPER_KEY=""       # Serper-API-Key (aktiviert die Such-Integration)
